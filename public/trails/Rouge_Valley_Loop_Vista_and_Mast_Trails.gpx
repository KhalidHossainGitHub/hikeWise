  <wpt lat="43.819441" lon="-79.1718699">
    <name><![CDATA[Alternate Parking]]></name>
    <desc><![CDATA[A few hundred metres away from the main trailhead parking, this is an alternate (and larger) parking lot to access to Vista trailhead.]]></desc>
  </wpt>
  <wpt lat="43.8119668" lon="-79.1542138">
    <name><![CDATA[River Trail]]></name>
    <desc><![CDATA[This is a shortcut to take the the River Trail instead of the main loop.]]></desc>
  </wpt>
